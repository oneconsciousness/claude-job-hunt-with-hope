# Hope plugin .gitignore

# ─── User runtime data (never committed) ──────────────────────────
# Hope writes a user's career files into the project folder it runs in.
# These patterns keep that data out of git if Hope is ever run inside this repo.
career-graph/
career.json
.hope-meta.json
.publish.json
site/

# ─── Internal contributor & governance docs (kept local) ──────────
# CONTRIBUTING.md is now PUBLIC — the agent-facing contributor guide ships with the plugin.
CLAUDE.md
references/design-cookbook.md
references/design-system.md

# ─── Internal session / planning / audit artifacts ────────────────
tasks/
_ground-truth-*.html

# ─── Agent infrastructure (local Claude Code config + hooks) ──────
.claude/

# ─── OS files ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Editors / IDEs ───────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Python ───────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# ─── Logs ─────────────────────────────────────────────────────────
*.log

# ─── Secrets / credentials (defense in depth) ─────────────────────
.env
.env.*
*.pem
*.key
credentials.*
secrets.*
